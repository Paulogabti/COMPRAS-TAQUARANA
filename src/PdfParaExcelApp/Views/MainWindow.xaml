<Window x:Class="PdfParaExcelApp.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="PDF para Excel" Height="760" Width="1120"
        Background="{StaticResource AppBackgroundBrush}"
        AllowDrop="True"
        Drop="Window_Drop"
        DragOver="Window_DragOver">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Conversor PDF → Excel" Style="{StaticResource TitleTextStyle}" />

        <Border Grid.Row="1" Style="{StaticResource CardStyle}" Margin="0,16,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="160"/>
                    <ColumnDefinition Width="160"/>
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0" Text="{Binding PdfPath, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ModernTextBox}"/>
                <Button Grid.Column="1" Content="Selecionar PDF" Command="{Binding SelectPdfCommand}" Style="{StaticResource SecondaryButton}" Margin="10,0,0,0"/>
                <Button Grid.Column="2" Content="Analisar" Command="{Binding AnalyzePdfCommand}" Style="{StaticResource PrimaryButton}" Margin="10,0,0,0"/>
            </Grid>
        </Border>

        <Grid Grid.Row="2" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="3*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource CardStyle}" Margin="0,0,12,0">
                <StackPanel>
                    <TextBlock Text="Colunas detectadas" Style="{StaticResource SectionTitleStyle}"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <Button Content="Marcar todas" Command="{Binding SelectAllColumnsCommand}" Style="{StaticResource SecondaryButton}"/>
                        <Button Content="Desmarcar todas" Command="{Binding DeselectAllColumnsCommand}" Style="{StaticResource SecondaryButton}" Margin="8,0,0,0"/>
                    </StackPanel>
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Height="190">
                        <ItemsControl ItemsSource="{Binding DetectedColumns}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <CheckBox Content="{Binding DisplayName}" IsChecked="{Binding IsSelected}" Margin="2" Foreground="{StaticResource ForegroundBrush}"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Text="Prévia" Style="{StaticResource SectionTitleStyle}"/>
                    <TextBlock Text="{Binding PreviewSummary}" Foreground="{StaticResource MutedForegroundBrush}" Margin="0,0,0,8"/>
                    <ListBox ItemsSource="{Binding PreviewRows}" Height="220" Background="{StaticResource SurfaceBrush}" BorderThickness="0" Foreground="{StaticResource ForegroundBrush}"/>
                </StackPanel>
            </Border>
        </Grid>

        <Border Grid.Row="3" Style="{StaticResource CardStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="180"/>
                    <ColumnDefinition Width="150"/>
                </Grid.ColumnDefinitions>

                <TextBox Grid.Column="0" Text="{Binding OutputPath, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ModernTextBox}"/>
                <Button Grid.Column="1" Content="Destino" Command="{Binding SelectOutputCommand}" Style="{StaticResource SecondaryButton}" Margin="10,0,0,0"/>
                <Button Grid.Column="2" Content="Gerar Excel" Command="{Binding ExportExcelCommand}" Style="{StaticResource PrimaryButton}" Margin="10,0,0,0"/>
            </Grid>
        </Border>

        <Border Grid.Row="4" Style="{StaticResource CardStyle}" Margin="0,12,0,0">
            <StackPanel>
                <TextBlock Text="Status" Style="{StaticResource SectionTitleStyle}"/>
                <TextBlock Text="{Binding StatusMessage}" TextWrapping="Wrap"/>
                <ProgressBar Value="{Binding ProgressValue}" Height="8" Margin="0,8,0,0" Maximum="100"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
